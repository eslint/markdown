{
  "include": ["src/**/*.js", "src/**/*.ts"],
  "compilerOptions": {
    "declaration": true,
    "allowJs": true,
    "checkJs": true,
    "outDir": "dist",
    "target": "ES2022",
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "rootDir": "./src",
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false,
    "types": ["mdast", "unist"]
  }
}
